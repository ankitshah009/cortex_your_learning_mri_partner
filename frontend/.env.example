# Full local live mode: local Cortex API for PDF import + live LLM diagnosis.
# Run `ANTHROPIC_API_KEY=... npm run api`, then set:
# VITE_CORTEX_API_URL=http://localhost:8787
# CORTEX_REASONING_MODEL=claude-haiku-4-5
# CORTEX_EXTRACTION_MODEL=claude-haiku-4-5

# Optional deployed live mode: Butterbase serverless analyze endpoint.
# POST { problemId, problem?: { title, statement }, reasoning } -> Diagnosis JSON (src/scenarios/types.ts).
# Works for any problem: the diagnosis is built from problem.statement + reasoning
# (problemId is only echoed back; if `problem` is omitted it is used as a text hint).
# Leave unset to run fully on seeded demo content.
# Current deployment (cortex app on Butterbase, frontend at https://cortex.butterbase.dev):
# VITE_ANALYZE_URL=https://api.butterbase.ai/v1/app_zqxy9ay6v4jw/fn/analyze

# Optional EverOS memory.
# VITE_EVEROS_API_KEY=...
# VITE_EVEROS_USER_ID=demo_student
