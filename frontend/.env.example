# Optional: real analyze endpoint (Butterbase serverless function, source in functions/analyze/).
# POST { problemId, problem?: { title, statement }, reasoning } -> Diagnosis JSON (src/scenarios/types.ts).
# Works for any problem: the diagnosis is built from problem.statement + reasoning
# (problemId is only echoed back; if `problem` is omitted it is used as a text hint).
# Leave unset to run fully on seeded demo content.
# VITE_ANALYZE_URL=https://api.butterbase.ai/v1/<app_id>/fn/analyze
